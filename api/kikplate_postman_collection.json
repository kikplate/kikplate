          "event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Status is 200\", () => pm.response.to.have.status(200));", "pm.test(\"Returns array\", () => { const body = pm.response.json(); pm.expect(body).to.be.an(\"array\"); });"] } }]
        }
      ]
    },
