            "body": { "mode": "raw", "raw": "{\n  \"email\": \"moe@example.com\",\n  \"password\": \"strongpassword123\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Status is 200\", () => pm.response.to.have.status(200));", "pm.test(\"Has token and account\", () => { const body = pm.response.json(); pm.expect(body.token).to.be.a(\"string\"); pm.expect(body.account).to.be.an(\"object\"); pm.collectionVariables.set(\"token\", body.token); });"] } }]
        },
