          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Status is 400\", () => pm.response.to.have.status(400));", "pm.test(\"Has error\", () => { const body = pm.response.json(); pm.expect(body.error).to.equal(\"token is required\"); });"] } }]
        },
