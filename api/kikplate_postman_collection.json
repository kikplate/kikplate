          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Status is 422\", () => pm.response.to.have.status(422));", "pm.test(\"Has error\", () => { const body = pm.response.json(); pm.expect(body.error).to.equal(\"token invalid or expired\"); });"] } }]
        },
