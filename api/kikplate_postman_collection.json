          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Status is 409\", () => pm.response.to.have.status(409));", "pm.test(\"Has error\", () => { const body = pm.response.json(); pm.expect(body.error).to.equal(\"email already registered\"); });"] } }]
