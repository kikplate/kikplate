            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Go Dockerfile\",\n  \"description\": \"Production-ready Dockerfile for Go services\",\n  \"category\": \"devops\",\n  \"visibility\": \"public\",\n  \"filename\": \"Dockerfile\",\n  \"content\": \"FROM golang:1.22-alpine AS builder\\nWORKDIR /app\\nCOPY . .\\nRUN go build -o main .\\n\\nFROM alpine:latest\\nCOPY --from=builder /app/main .\\nENTRYPOINT [\\\"/main\\\"]\",\n  \"tags\": [\"go\", \"docker\", \"devops\"]\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Status is 201\", () => pm.response.to.have.status(201));", "pm.test(\"Has plate with correct fields\", () => { const body = pm.response.json(); pm.expect(body.id).to.be.a(\"string\"); pm.expect(body.type).to.equal(\"file\"); pm.expect(body.is_verified).to.equal(true); pm.expect(body.filename).to.equal(\"Dockerfile\"); pm.collectionVariables.set(\"plate_id\", body.id); pm.collectionVariables.set(\"plate_slug\", body.slug); });"] } }]
