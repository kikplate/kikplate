        },
        {
          "name": "Submit Repository Plate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/plates/repository", "host": ["{{base_url}}"], "path": ["plates", "repository"] },
            "body": { "mode": "raw", "raw": "{\n  \"repo_url\": \"https://github.com/MoeidHeidari/dummy-boilerplate\",\n  \"branch\": \"main\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Status is 201\", () => pm.response.to.have.status(201));", "pm.test(\"Has plate with id and slug\", () => { const body = pm.response.json(); pm.expect(body.id).to.be.a(\"string\"); pm.expect(body.slug).to.be.a(\"string\"); pm.expect(body.type).to.equal(\"repository\"); pm.expect(body.is_verified).to.equal(true); pm.collectionVariables.set(\"plate_id\", body.id); pm.collectionVariables.set(\"plate_slug\", body.slug); });"] } }]
