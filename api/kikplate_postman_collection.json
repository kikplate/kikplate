{
  "info": {
    "name": "Kickplate API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "token", "value": "" },
    { "key": "verification_token", "value": "" },
    { "key": "plate_id", "value": "" },
    { "key": "plate_slug", "value": "" }
